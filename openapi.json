{
    "openapi": "3.1.0",
    "info": {
        "title": "Recommendation API",
        "description": "API de recomendações de recursos por competência",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080",
            "description": "Generated server url"
        }
    ],
    "security": [
        {
            "bearerAuth": []
        }
    ],
    "tags": [
        {
            "name": "Catálogo de Recursos",
            "description": "CRUD completo para gerenciamento dos recursos recomendáveis"
        },
        {
            "name": "Recomendações",
            "description": "Geração, consulta e remoção de recomendações"
        }
    ],
    "paths": {
        "/api/resources/{id}": {
            "get": {
                "tags": [
                    "Catálogo de Recursos"
                ],
                "summary": "Buscar recurso por ID",
                "description": "Retorna os detalhes de um recurso específico baseado no ID",
                "operationId": "getResourceById",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResourceDTO"
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "tags": [
                    "Catálogo de Recursos"
                ],
                "summary": "Atualizar recurso",
                "description": "Edita os dados de um recurso existente no catálogo",
                "operationId": "updateResource",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ResourceDTO"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResourceDTO"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "Catálogo de Recursos"
                ],
                "summary": "Remover recurso",
                "description": "Deleta um recurso específico do catálogo pelo ID",
                "operationId": "deleteResource",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/resources": {
            "get": {
                "tags": [
                    "Catálogo de Recursos"
                ],
                "summary": "Listar todos os recursos",
                "description": "Retorna uma lista com todos os recursos cadastrados",
                "operationId": "getAllResources",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/ResourceDTO"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Catálogo de Recursos"
                ],
                "summary": "Criar recurso",
                "description": "Cadastra un novo recurso no catálogo",
                "operationId": "createResource",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ResourceDTO"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ResourceDTO"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/recommendations/evaluate": {
            "post": {
                "tags": [
                    "Recomendações"
                ],
                "summary": "Acionar recomendação",
                "description": "Recebe dados do serviço de avaliação e gera uma recomendação",
                "operationId": "generateRecommendation",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AssessmentTriggerDTO"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Recomendações geradas"
                    },
                    "400": {
                        "description": "Dados inválidos"
                    },
                    "401": {
                        "description": "Token inválido ou ausente"
                    },
                    "404": {
                        "description": "Competência sem recursos"
                    }
                }
            }
        },
        "/api/recommendations/user/{userId}": {
            "get": {
                "tags": [
                    "Recomendações"
                ],
                "summary": "Listar por usuário",
                "description": "Retorna todas as recomendações vinculadas a um ID de usuário",
                "operationId": "getUserRecommendations",
                "parameters": [
                    {
                        "name": "userId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    },
                    {
                        "name": "pageable",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "$ref": "#/components/schemas/Pageable"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de recomendações",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/RecommendationDTO"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Token inválido ou ausente",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/RecommendationDTO"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/recommendations/{id}": {
            "delete": {
                "tags": [
                    "Recomendações"
                ],
                "summary": "Remover recomendação",
                "description": "Deleta uma recomendação específica pelo ID",
                "operationId": "deleteRecommendation",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Removido com sucesso"
                    },
                    "401": {
                        "description": "Token inválido ou ausente"
                    },
                    "404": {
                        "description": "Recomendação não encontrada"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ResourceDTO": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID único do recurso (Gerado automaticamente)",
                        "readOnly": true
                    },
                    "name": {
                        "type": "string",
                        "description": "Nome do recurso",
                        "example": "Introdução ao Smartphone"
                    },
                    "description": {
                        "type": "string",
                        "description": "Descrição detalhada",
                        "example": "Vídeo tutorial de 10 min para iniciantes"
                    },
                    "url": {
                        "type": "string",
                        "description": "Link de acesso ao recurso",
                        "example": "https://youtube.com/..."
                    },
                    "competencyId": {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID da competência associada",
                        "example": 1
                    },
                    "level": {
                        "type": "string",
                        "description": "Nível de dificuldade",
                        "enum": [
                            "BEGINNER",
                            "INTERMEDIATE",
                            "ADVANCED"
                        ],
                        "example": "BEGINNER"
                    }
                },
                "required": [
                    "level"
                ]
            },
            "AssessmentTriggerDTO": {
                "type": "object",
                "properties": {
                    "userId": {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID do usuário avaliado",
                        "example": 42
                    },
                    "competencyId": {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID da competência avaliada",
                        "example": 3
                    },
                    "level": {
                        "type": "string",
                        "description": "Nível atingido pelo usuário",
                        "enum": [
                            "BEGINNER",
                            "INTERMEDIATE",
                            "ADVANCED"
                        ],
                        "example": "INTERMEDIATE"
                    }
                },
                "required": [
                    "competencyId",
                    "level",
                    "userId"
                ]
            },
            "Pageable": {
                "type": "object",
                "properties": {
                    "page": {
                        "type": "integer",
                        "format": "int32",
                        "minimum": 0
                    },
                    "size": {
                        "type": "integer",
                        "format": "int32",
                        "minimum": 1
                    },
                    "sort": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "RecommendationDTO": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID único da recomendação",
                        "readOnly": true
                    },
                    "userId": {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID do usuário"
                    },
                    "resource": {
                        "$ref": "#/components/schemas/ResourceDTO",
                        "description": "Recurso que foi recomendado"
                    },
                    "description": {
                        "type": "string",
                        "description": "Justificativa da recomendação"
                    }
                }
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
}