# Garante LF em scripts shell (evita CRLF que quebra execução no Linux/CI)
*.sh text eol=lf
mvnw text eol=lf
*.cmd text eol=crlf

# Arquivos de código
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.properties text eol=lf
*.xml text eol=lf

# Binários
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.jar binary
*.war binary
